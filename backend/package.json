{
  "name": "whaviso",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run lint && npm run typecheck",
    "test": "npm run test --workspaces --if-present",
    "dev:api": "npm run dev -w @whaviso/api",
    "dev:zap": "npm run dev -w @whaviso/zap"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-boundaries": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.30.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "unrs-resolver@1.12.2": true,
    "protobufjs@6.8.8": true,
    "protobufjs@6.11.6": true
  }
}
