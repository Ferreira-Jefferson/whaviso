# backend/ é um projeto independente (install próprio). Este .gitignore garante
# proteção mesmo se o git for inicializado AQUI dentro, e não na raiz (caso em
# que o .gitignore da raiz não se aplicaria).

node_modules/
dist/
*.log

# segredos: ignora todo .env, menos os templates *.example versionáveis.
.env
.env.*
!.env.example
!.env.test.example

# Supabase CLI (estado local, não versionar)
supabase/.temp/
supabase/.branches/

.DS_Store
