# whaviso — template do .env ÚNICO de desenvolvimento local.
# Copie para .env (gitignored) e preencha. Produção: ver secrets/production.env.example.

# ── Postgres LOCAL (dev/testes; Postgres 18 sem Docker) ──
POSTGRES_PASSWORD=

# ── Supabase cloud ──
SUPABASE_PROJECT_ID=
SUPABASE_PROJECT_NAME=
SUPABASE_URL=
SUPABASE_PASSWORD=
# Service role key (segredo de SERVIDOR; NUNCA no front). Usada pela api só para a
# conta-no-aceite (H1.4): cria a conta do convidado por telefone via Admin API do
# Supabase. Opcional: sem ela, o aceite só vincula por telefone (sem criar conta).
SUPABASE_SERVICE_ROLE_KEY=

# ── api (:3001) — prefixo API_ ──
API_PORT=3001
API_DATABASE_URL=postgresql://whaviso_api:whaviso_api_dev@127.0.0.1:5432/whaviso_dev
APP_URL=http://localhost:5173
# Número do WhatsApp do Whaviso (só dígitos com DDI). Usado p/ montar o link wa.me do
# CONVITE (H2.2): o devedor fala com o Whaviso, não com o cobrador. Opcional: sem ele a
# tela de convite cai no fallback de copiar a mensagem/número.
# API_WHAVISO_WHATSAPP=5511999998888

# ── zap (:3002) — prefixo ZAP_ ──
ZAP_PORT=3002
ZAP_DATABASE_URL=postgresql://whaviso_zap:whaviso_zap_dev@127.0.0.1:5432/whaviso_dev
SCHEDULER_INTERVAL_MS=30000
# Origem do SPA p/ a CTA discreta de criar conta ao cobrador SEM conta (H10.7). Opcional:
# se ausente, o zap reaproveita o APP_URL acima (server.ts faz o alias).
# ZAP_APP_URL=http://localhost:5173

# WhatsApp via Baileys (não oficial; transporte atual até ~100 clientes). A sessão
# fica em WHATS_AUTH_DIR (precisa persistir; pareie escaneando o QR no 1º boot).
WHATS_AUTH_DIR=./auth_baileys
# WHATS_PHONE=5511999998888   # só dígitos; preencha p/ usar pairing code em vez de QR
# WHATS_USE_PAIRING=false
WHATS_BROWSER=Whaviso
WHATS_HUMANIZE=true
# WHATS_DRY_RUN=true          # simula a cadência sem enviar de verdade (testes locais)
# Ritmo anti-bloqueio (ms / por hora):
WHATS_GAP_MIN=8000
WHATS_GAP_MAX=20000
WHATS_BATCH_SIZE=20
WHATS_BATCH_PAUSE_MIN=60000
WHATS_BATCH_PAUSE_MAX=180000
WHATS_MAX_POR_HORA=60
# OTP do login por telefone (Send SMS Hook do Supabase). Sem o secret, /hooks/sms responde 503.
# SEND_SMS_HOOK_SECRET=

# ── frontend (React + Vite SPA → Vercel) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_API_URL=http://localhost:3001

# ── compartilhado ──
LOG_LEVEL=info
