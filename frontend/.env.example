VITE_API_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Client ID público do Google (login via Identity Services); termina em .apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=
# Número do WhatsApp de vendas (só dígitos, com DDI) para o link "abrir conversa" na recarga.
# Ex.: 5511999999999. IMPORTANTE: deve ser o MESMO número pareado pelo zap/Baileys: a mensagem
# de compra (template billing.recarga + Pix) é EMPURRADA por esse número e o comprovante do
# usuário volta nessa mesma conversa. Se divergir, o comprovante cai noutro número.
VITE_WHATSAPP_VENDAS=
