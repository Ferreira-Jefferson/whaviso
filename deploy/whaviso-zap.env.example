# whaviso zap (scheduler + WhatsApp via Meta Cloud API, :3002): env de PRODUCAO no servidor.
# Instalar em /etc/whaviso/zap.env  (dono root:whaviso, modo 640).
# NAO commitar com valores reais. Os SEGREDOS estao em secrets/production.env
# (do repo, gitignored): copie de la os valores marcados <copiar de production.env>.
#
# Este arquivo carrega SO os segredos do zap. A api tem o seu proprio (/etc/whaviso/api.env).
# Separar por servico evita que um processo carregue os segredos do outro no ambiente:
# comprometer o zap (que fala com a internet: webhook Meta, Send SMS Hook) NAO expoe a
# string de conexao do whaviso_api.

# ════════════════ zap (:3002) ════════════════
ZAP_PORT=3002
# Conexao do banco (role whaviso_zap). Veja o apendice "Banco" no README:
# use a string DIRETA (IPv6) se o VPS tiver IPv6, ou a do SESSION POOLER (IPv4, :5432).
ZAP_DATABASE_URL=<copiar de production.env / ver apendice Banco>
SCHEDULER_INTERVAL_MS=30000
# Origem do SPA para a CTA de cadastro ao cobrador sem conta (H10.7).
ZAP_APP_URL=https://whaviso.com

# ── WhatsApp via Meta Cloud API (oficial) ──
# O zap fala com a Graph API por HTTP (sem socket, sem QR): a conexao e por
# credenciais. As 4 primeiras sao exigidas no boot; sem elas o zap encerra.
META_ACCESS_TOKEN=       # token permanente do System User (whatsapp_business_messaging + management)
META_PHONE_NUMBER_ID=    # Phone number ID (WhatsApp Manager / API Setup)
META_WABA_ID=            # WhatsApp Business Account ID
META_APP_SECRET=         # app secret (valida a assinatura do webhook)
META_VERIFY_TOKEN=       # token do handshake do webhook (voce escolhe)
META_GRAPH_URL=https://graph.facebook.com
META_API_VERSION=v23.0
# OTP do login por telefone (Send SMS Hook do Supabase). So preencha ao habilitar o OTP
# (ver apendice OTP no README). Sem o secret, /hooks/send-code responde 503.
# SEND_CODE_HOOK_SECRET=

# ── Conta-no-aceite (H5.3): Admin API do GoTrue ──
# No ACEITE pelo WhatsApp o zap cria a conta do convidado por baixo dos panos (por
# telefone confirmado) via Admin API. Sem estas duas, o aceite so vincula por telefone
# (degrada sem quebrar). A URL do Supabase e publica; a service role key e segredo.
SUPABASE_URL=https://exxczsyjvgjsxmwlrwww.supabase.co
# RESIDUO DO H1: a service role key bypassa o RLS por completo e habilita a Admin API.
# Hoje os DOIS processos (api E zap) a usam, entao ela vive aqui E no /etc/whaviso/api.env.
# O zap e internet-facing, entao esta e a maior exposicao residual: refactor futuro deve
# mover a criacao de conta para um unico ponto (idealmente so a api) e tirar esta chave do
# zap. Enquanto isso: rotacione as duas copias juntas e trate vazamento como incidente total.
SUPABASE_SERVICE_ROLE_KEY=<copiar de production.env>

# ════════════════ compartilhado ════════════════
LOG_LEVEL=info
