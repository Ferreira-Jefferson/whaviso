# whaviso api (REST, :3001): env de PRODUCAO no servidor.
# Instalar em /etc/whaviso/api.env  (dono root:whaviso, modo 640).
# NAO commitar com valores reais. Os SEGREDOS estao em secrets/production.env
# (do repo, gitignored): copie de la os valores marcados <copiar de production.env>.
#
# Este arquivo carrega SO os segredos da api. O zap tem o seu proprio (/etc/whaviso/zap.env).
# Separar por servico evita que um processo carregue os segredos do outro no ambiente:
# comprometer a api NAO expoe a string de conexao do whaviso_zap nem os META_*.

# ════════════════ api (:3001) ════════════════
API_PORT=3001
# Conexao do banco (role whaviso_api). Veja o apendice "Banco" no README:
# use a string DIRETA (IPv6) se o VPS tiver IPv6, ou a do SESSION POOLER (IPv4, :5432).
API_DATABASE_URL=<copiar de production.env / ver apendice Banco>
SUPABASE_URL=https://exxczsyjvgjsxmwlrwww.supabase.co
APP_URL=https://whaviso.com
# Service role key (segredo de servidor). A api a usa para a conta-no-aceite (H1.4)
# via Admin API do GoTrue. ATENCAO: hoje o zap TAMBEM usa esta chave (residuo do H1),
# entao ela precisa estar tambem no /etc/whaviso/zap.env. Rotacione as duas copias juntas.
SUPABASE_SERVICE_ROLE_KEY=<copiar de production.env>
# Numero do WhatsApp do Whaviso para o link wa.me do convite (opcional, so digitos com DDI)
# API_WHAVISO_WHATSAPP=55XXXXXXXXXXX

# ════════════════ compartilhado ════════════════
LOG_LEVEL=info
