# whaviso: env de PRODUCAO no servidor (api + zap leem o mesmo arquivo).
# Instalar em /etc/whaviso/whaviso.env  (dono root:whaviso, modo 640).
# NAO commitar com valores reais. Os SEGREDOS estao em secrets/production.env
# (do repo, gitignored): copie de la os valores marcados <copiar de production.env>.
#
# api e zap fazem alias do prefixo: API_PORT->PORT, ZAP_PORT->PORT, etc. Por isso
# o mesmo arquivo serve aos dois: cada processo le so o seu prefixo.

# ════════════════ api (:3001) ════════════════
API_PORT=3001
# Conexao do banco (role whaviso_api). Veja o apendice "Banco" no README:
# use a string DIRETA (IPv6) se o VPS tiver IPv6, ou a do SESSION POOLER (IPv4, :5432).
API_DATABASE_URL=<copiar de production.env / ver apendice Banco>
SUPABASE_URL=https://exxczsyjvgjsxmwlrwww.supabase.co
APP_URL=https://whaviso.com
# Service role key (segredo de servidor). Liga a conta-no-aceite (H1.4).
SUPABASE_SERVICE_ROLE_KEY=<copiar de production.env>
# Numero do WhatsApp do Whaviso para o link wa.me do convite (opcional, so digitos com DDI)
# API_WHAVISO_WHATSAPP=55XXXXXXXXXXX

# ════════════════ zap (:3002) ════════════════
ZAP_PORT=3002
ZAP_DATABASE_URL=<copiar de production.env / ver apendice Banco>
SCHEDULER_INTERVAL_MS=30000
# Origem do SPA para a CTA de cadastro (se ausente, herda o APP_URL acima)
ZAP_APP_URL=https://whaviso.com

# ── WhatsApp via Meta Cloud API (oficial) ──
# O zap fala com a Graph API por HTTP (sem socket, sem QR): a conexao e por
# credenciais. As 4 primeiras sao exigidas no boot; sem elas o zap encerra.
META_ACCESS_TOKEN=       # token permanente do System User (whatsapp_business_messaging + management)
META_PHONE_NUMBER_ID=    # Phone number ID (WhatsApp Manager / API Setup)
META_WABA_ID=            # WhatsApp Business Account ID
META_APP_SECRET=         # app secret (valida a assinatura do webhook)
META_VERIFY_TOKEN=       # token do handshake do webhook (voce escolhe)
META_GRAPH_URL=https://graph.facebook.com
META_API_VERSION=v23.0
# OTP do login por telefone (Send SMS Hook do Supabase). So preencha ao habilitar o OTP
# (ver apendice OTP no README). Sem o secret, /hooks/send-code responde 503.
# SEND_CODE_HOOK_SECRET=

# ════════════════ compartilhado ════════════════
LOG_LEVEL=info
