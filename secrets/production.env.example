# whaviso — template dos SEGREDOS DE PRODUÇÃO.
# Copie para secrets/production.env (gitignored) e preencha os valores reais.
# Push: bash scripts/push_secrets.sh <vercel|api|zap>

# ══ FRONTEND (React+Vite) → Vercel ══
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_API_URL=

# ══ API → host a definir ══
API_DATABASE_URL=
SUPABASE_URL=
APP_URL=

# ══ ZAP → host a definir ══
ZAP_DATABASE_URL=
# WhatsApp via Meta Cloud API (oficial). O zap fala com a Graph API por HTTP (sem
# socket, sem QR): a conexão é por credenciais. As 4 primeiras são exigidas no boot.
META_ACCESS_TOKEN=       # token permanente do System User (messaging + management)
META_PHONE_NUMBER_ID=    # Phone number ID (WhatsApp Manager / API Setup)
META_WABA_ID=            # WhatsApp Business Account ID
META_APP_SECRET=         # app secret (valida a assinatura do webhook)
META_VERIFY_TOKEN=       # token do handshake do webhook (você escolhe)
META_GRAPH_URL=https://graph.facebook.com
META_API_VERSION=v23.0
# SEND_CODE_HOOK_SECRET=   # OTP do login por telefone (Send SMS Hook do Supabase)
