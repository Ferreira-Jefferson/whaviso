# whaviso — template dos SEGREDOS DE PRODUÇÃO.
# Copie para secrets/production.env (gitignored) e preencha os valores reais.
# Push: bash scripts/push_secrets.sh <vercel|api|zap>

# ══ FRONTEND (React+Vite) → Vercel ══
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_API_URL=

# ══ API → host a definir ══
API_DATABASE_URL=
SUPABASE_URL=
APP_URL=

# ══ ZAP → host a definir ══
ZAP_DATABASE_URL=
# WhatsApp via Baileys (não oficial). auth_baileys/ precisa de diretório PERSISTENTE
# (volume) e processo ÚNICO (lock). Pareie escaneando o QR no 1º boot (tela de admin).
WHATS_AUTH_DIR=/var/lib/whaviso/auth_baileys
# WHATS_PHONE=          # só dígitos; p/ pairing code em vez de QR
# WHATS_USE_PAIRING=false
WHATS_BROWSER=Whaviso
WHATS_HUMANIZE=true
WHATS_GAP_MIN=8000
WHATS_GAP_MAX=20000
WHATS_BATCH_SIZE=20
WHATS_BATCH_PAUSE_MIN=60000
WHATS_BATCH_PAUSE_MAX=180000
WHATS_MAX_POR_HORA=60
# SEND_CODE_HOOK_SECRET=   # OTP do login por telefone (Send SMS Hook do Supabase)
